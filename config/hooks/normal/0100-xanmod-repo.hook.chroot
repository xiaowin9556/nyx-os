#!/bin/sh
set -e
mkdir -p /etc/apt/keyrings
curl -fsSL https://liquorix.net/liquorix-keyring.gpg | gpg --batch --yes --dearmor -o /etc/apt/keyrings/liquorix-keyring.gpg
codename=$(grep VERSION_CODENAME /etc/os-release | cut -d= -f2)
echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/liquorix-keyring.gpg] https://liquorix.net/debian $codename main" > /etc/apt/sources.list.d/liquorix.list
apt-get update
apt-get install -y linux-image-liquorix-amd64 linux-headers-liquorix-amd64
